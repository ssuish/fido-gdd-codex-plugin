{
  "name": "gdd-drift-showcase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit",
    "test": "node --test --experimental-strip-types",
    "sync:game": "node scripts/sync-game-r2.mjs",
    "strip:game": "node scripts/strip-game-from-dist.mjs",
    "deploy": "npm run build && npm run sync:game && npm run strip:game && wrangler deploy",
    "deploy:preview": "npm run sync:game && npm run strip:game && wrangler versions upload"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "wrangler": "^4.112.0"
  }
}
